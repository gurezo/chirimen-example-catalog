{
  "name": "chirimen-example-catalog",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.0.0",
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=11 <12"
  },
  "scripts": {
    "sync:upstreams": "tsx tools/sync-upstreams/src/main.ts",
    "catalog:generate": "tsx tools/generate-catalog/src/main.ts",
    "docs:generate": "tsx tools/generate-docs/src/main.ts",
    "metadata:validate": "tsx tools/validate-metadata/src/main.ts",
    "duplicates:detect": "tsx tools/detect-duplicates/src/main.ts",
    "docs:build": "honkit build docs public",
    "validate": "pnpm metadata:validate && pnpm catalog:generate && pnpm docs:generate",
    "build": "pnpm docs:generate && pnpm docs:build"
  },
  "devDependencies": {
    "honkit": "latest",
    "tsx": "latest",
    "typescript": "latest"
  }
}
